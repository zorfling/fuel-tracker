generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("NETLIFY_DATABASE_URL")
}

model TrackedLocation {
  id        String   @id @default(cuid())
  latQ      Float    // quantized to 2 decimal places
  lngQ      Float    // quantized to 2 decimal places
  name      String   // human-friendly display name
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots PriceSnapshot[]
  alerts   PriceAlert[]

  @@unique([latQ, lngQ])
  @@index([latQ, lngQ])
}

model PriceAlert {
  id            String   @id @default(cuid())
  locationId    String
  fuelTypeId    Int
  threshold     Float    // cents per litre — alert when cheapest drops below this
  enabled       Boolean  @default(true)
  lastTriggered DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  location TrackedLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, fuelTypeId])
  @@index([enabled])
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  locationId String
  fuelTypeId Int
  cheapest   Float
  median     Float
  average    Float
  stationCount Int
  timestamp  DateTime @default(now())

  location TrackedLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, fuelTypeId, timestamp])
  @@index([timestamp])
}
